{
  "name": "agenc-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@11.7.0",
  "workspaces": [
    "contracts/desktop-tool-contracts",
    "runtime",
    "mcp",
    "docs-mcp",
    "test-fixtures/plugin-kit-channel-adapter",
    "web",
    "mobile",
    "demo-app",
    "containers/desktop/server",
    "examples/autonomous-agent",
    "examples/dispute-arbiter",
    "examples/event-dashboard",
    "examples/llm-agent",
    "examples/memory-agent",
    "examples/risc0-proof-demo",
    "examples/simple-usage",
    "examples/skill-jupiter",
    "examples/tetsuo-integration",
    "examples/helius-webhook",
    "tools/localnet-social",
    "tools/proof-harness"
  ],
  "scripts": {
    "build": "npm run build --workspace=@tetsuo-ai/runtime && npm run build --workspace=@tetsuo-ai/mcp && npm run build --workspace=@tetsuo-ai/docs-mcp",
    "build:private-kernel": "npm run build --workspace=@tetsuo-ai/desktop-tool-contracts && npm run build --workspace=@tetsuo-ai/runtime && npm run build --workspace=@tetsuo-ai/mcp && npm run build --workspace=@tetsuo-ai/docs-mcp && npm run build --workspace=@tetsuo-ai/desktop-server",
    "build:runtime": "npm run build --workspace=@tetsuo-ai/runtime",
    "build:mcp": "npm run build --workspace=@tetsuo-ai/mcp",
    "check:public-contract-boundary": "node scripts/check-public-contract-boundary.mjs",
    "check:private-kernel-surface": "node scripts/check-private-kernel-surface.mjs",
    "check:private-kernel-distribution": "node scripts/private-kernel-distribution.mjs --check",
    "check:private-kernel-distribution:local": "node scripts/private-kernel-distribution.mjs --check --config config/private-kernel-distribution.local.json",
    "check:proof-harness-boundary": "node scripts/check-proof-harness-boundary.mjs",
    "stage:private-kernel-distribution": "node scripts/private-kernel-distribution.mjs --stage",
    "stage:private-kernel-distribution:local": "node scripts/private-kernel-distribution.mjs --stage --config config/private-kernel-distribution.local.json",
    "dry-run:private-kernel-distribution": "node scripts/private-kernel-distribution.mjs --dry-run",
    "dry-run:private-kernel-distribution:local": "node scripts/private-kernel-distribution.mjs --dry-run --config config/private-kernel-distribution.local.json",
    "private-registry:up": "node scripts/private-registry-service.mjs start --mode locked",
    "private-registry:down": "node scripts/private-registry-service.mjs stop",
    "private-registry:logs": "node scripts/private-registry-service.mjs logs --follow",
    "private-registry:status": "node scripts/private-registry-service.mjs status",
    "private-registry:health": "node scripts/private-registry-service.mjs health --wait-ms 15000",
    "private-registry:reset": "node scripts/private-registry-service.mjs reset",
    "private-registry:bootstrap": "node scripts/bootstrap-private-registry-user.mjs",
    "private-registry:rehearse": "node scripts/private-registry-rehearsal.mjs --expect-public-scope-publish-denied",
    "pack:smoke": "npm run build && node scripts/pack-smoke.mjs",
    "pack:smoke:skip-build": "node scripts/pack-smoke.mjs",
    "test:private-registry-scripts": "node --test scripts/private-registry-service.test.mjs scripts/bootstrap-private-registry-user.test.mjs scripts/private-kernel-distribution.test.mjs scripts/private-registry-rehearsal.test.mjs",
    "test": "npm run test --workspace=@tetsuo-ai/runtime",
    "test:fast": "npx ts-mocha -p ./tsconfig.json -t 300000 tests/test-create-task.ts tests/test-claim-task.ts tests/test-lifecycle.ts tests/test-state-machine.ts tests/test-authority.ts tests/test-audit-gaps.ts tests/test-escrow.ts tests/test-disputes.ts tests/test-reputation-stake.ts tests/test-concurrency.ts tests/test-invariants.ts tests/test-reputation-gate.ts tests/agent-feed.ts",
    "typecheck": "npm run typecheck --workspace=@tetsuo-ai/runtime && npm run typecheck --workspace=@tetsuo-ai/mcp && npm run typecheck --workspace=@tetsuo-ai/proof-harness-tools",
    "example:autonomous-agent": "npm run start --workspace=@tetsuo-ai/example-autonomous-agent --",
    "example:dispute-arbiter": "npm run start --workspace=@tetsuo-ai/example-dispute-arbiter --",
    "example:event-dashboard": "npm run start --workspace=@tetsuo-ai/example-event-dashboard --",
    "example:llm-agent": "npm run start --workspace=@tetsuo-ai/example-llm-agent --",
    "example:memory-agent": "npm run start --workspace=@tetsuo-ai/example-memory-agent --",
    "example:risc0-proof-demo": "npm run start --workspace=@tetsuo-ai/example-risc0-proof-demo --",
    "example:skill-jupiter": "npm run start --workspace=@tetsuo-ai/example-skill-jupiter --",
    "localnet:social:bootstrap": "npm run bootstrap --workspace=@tetsuo-ai/localnet-social-tools --",
    "localnet:social:smoke": "npm run smoke --workspace=@tetsuo-ai/localnet-social-tools --",
    "benchmark:private:e2e": "npm run benchmark:e2e --workspace=@tetsuo-ai/proof-harness-tools --"
  },
  "overrides": {
    "bn.js": "^5.2.3",
    "rollup": "^4.59.0"
  },
  "dependencies": {
    "@tetsuo-ai/protocol": "0.1.1",
    "markdown-it": "^14.1.1",
    "tsx": "^4.7.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/web3.js": "^1.98.4",
    "bn.js": "^5.2.3",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
