+    def set_god_mode(self, enabled: bool = True) -> dict:
+        """Enable or disable Doom god mode deterministically."""
+        game = self._require_running()
+
+        with self._with_executor_paused():
+            with self._game_lock:
+                changed = self._apply_god_mode_locked(game, enabled)
+                health = game.get_game_variable(vzd.GameVariable.HEALTH)
+                damage_taken = game.get_game_variable(vzd.GameVariable.DAMAGE_TAKEN)
+
+        return {
+            "status": "god_mode_updated" if changed else "god_mode_unchanged",
+            "god_mode_enabled": self._god_mode_enabled,
