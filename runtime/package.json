{
  "name": "@agenc/runtime",
  "version": "0.1.0",
  "description": "Agent runtime infrastructure for AgenC coordination on Solana",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "agenc-runtime": "dist/bin/agenc-runtime.js",
    "agenc": "dist/bin/agenc.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./operator-events": {
      "types": "./dist/operator-events.d.ts",
      "import": "./dist/operator-events.mjs",
      "require": "./dist/operator-events.js"
    }
  },
  "files": [
    "dist",
    "idl",
    "README.md"
  ],
  "scripts": {
    "generate:desktop-tool-definitions": "npx tsx scripts/generate-desktop-tool-definitions.ts",
    "check:desktop-tool-definitions": "npx tsx scripts/generate-desktop-tool-definitions.ts --check",
    "sync:sdk": "npm install --no-save --ignore-scripts ../sdk",
    "prebuild": "npm run build --prefix ../sdk && npm run sync:sdk && npm run check:desktop-tool-definitions && node scripts/copy-idl.js",
    "build": "tsup src/index.ts src/operator-events.ts src/bin/agenc.ts src/bin/agenc-runtime.ts src/bin/daemon.ts --format cjs,esm --dts --clean --external openai --external ollama --external better-sqlite3 --external ioredis --external @solana/spl-token --external ws --external grammy --external discord.js --external @slack/bolt --external @whiskeysockets/baileys --external matrix-js-sdk --external cheerio --external playwright --external edge-tts --external @modelcontextprotocol/sdk",
    "pretypecheck": "npm run build --prefix ../sdk && npm run sync:sdk && npm run check:desktop-tool-definitions",
    "typecheck": "tsc --noEmit",
    "check-idl-drift": "tsx scripts/check-idl-drift.ts",
    "pretest": "npm run build --prefix ../sdk && npm run sync:sdk && npm run check:desktop-tool-definitions",
    "test": "vitest run",
    "test:watch": "vitest",
    "repro:pipeline:http": "npx tsx scripts/repro-pipeline-http.ts",
    "benchmark": "npx tsx scripts/run-benchmarks.ts",
    "benchmark:ci": "npx tsx scripts/run-benchmarks.ts --output benchmarks/artifacts/ci.json",
    "benchmark:pipeline": "npx tsx scripts/run-pipeline-quality.ts",
    "benchmark:pipeline:ci": "npx tsx scripts/run-pipeline-quality.ts --output benchmarks/artifacts/pipeline-quality.ci.json",
    "benchmark:pipeline:gates": "npx tsx scripts/check-pipeline-gates.ts --artifact benchmarks/artifacts/pipeline-quality.ci.json",
    "benchmark:background-runs": "npx tsx scripts/run-background-run-quality.ts",
    "benchmark:background-runs:ci": "npx tsx scripts/run-background-run-quality.ts --output benchmarks/artifacts/background-run-quality.ci.json",
    "benchmark:background-runs:gates": "npx tsx scripts/check-background-run-gates.ts",
    "autonomy:rollout:gates": "npx tsx scripts/check-autonomy-rollout-gates.ts --mode limited",
    "benchmark:delegation": "npx tsx scripts/run-delegation-benchmarks.ts --output benchmarks/artifacts/delegation-benchmark.latest.json",
    "benchmark:delegation:ci": "npx tsx scripts/run-pipeline-quality.ts --output benchmarks/artifacts/delegation-quality.ci.json --desktop-runs 0 --delegation-k 2",
    "benchmark:delegation:gates": "npx tsx scripts/check-pipeline-gates.ts --artifact benchmarks/artifacts/delegation-quality.ci.json",
    "benchmark:decomposition-search": "npx tsx scripts/run-decomposition-search.ts --output benchmarks/artifacts/decomposition-search.latest.json",
    "mutation": "npx tsx scripts/run-mutations.ts",
    "mutation:ci": "npx tsx scripts/run-mutations.ts --output benchmarks/artifacts/mutation.ci.json --trend-output benchmarks/artifacts/mutation-trend.ci.json",
    "mutation:gates": "npx tsx scripts/check-mutation-gates.ts --artifact benchmarks/artifacts/mutation.ci.json",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "solana",
    "agents",
    "runtime",
    "coordination",
    "privacy",
    "zk"
  ],
  "author": "Tetsuo AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tetsuo-ai/AgenC",
    "directory": "runtime"
  },
  "optionalDependencies": {
    "@slack/bolt": "^4.6.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "better-sqlite3": "^12.6.2",
    "cheerio": "^1.2.0",
    "discord.js": "^14.25.1",
    "edge-tts": "^1.0.1",
    "grammy": "^1.41.1",
    "ioredis": "^5.10.0",
    "matrix-js-sdk": "^41.1.0-rc.0",
    "ollama": "^0.6.3",
    "openai": "^6.27.0",
    "playwright": "^1.58.2",
    "ws": "^8.19.0"
  },
  "overrides": {
    "@hono/node-server": "^1.19.11",
    "bn.js": "^5.2.3",
    "bigint-buffer": "file:../patches/npm/bigint-buffer",
    "express-rate-limit": "^8.3.1",
    "matrix-js-sdk": "^41.1.0-rc.0",
    "rollup": "^4.59.0",
    "undici": "^7.22.0"
  },
  "resolutions": {
    "@hono/node-server": "^1.19.11",
    "bn.js": "^5.2.3",
    "bigint-buffer": "file:../patches/npm/bigint-buffer",
    "express-rate-limit": "^8.3.1",
    "matrix-js-sdk": "^41.1.0-rc.0",
    "rollup": "^4.59.0",
    "undici": "^7.22.0"
  },
  "dependencies": {
    "@agenc/sdk": "file:../sdk",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "undici": "^7.22.0"
  },
  "devDependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.4.0",
    "@types/ws": "^8.18.1",
    "anchor-litesvm": "^0.2.1",
    "bs58": "^6.0.0",
    "litesvm": "^0.6.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@coral-xyz/anchor": ">=0.29.0",
    "@solana/spl-token": ">=0.4.0",
    "@solana/web3.js": ">=1.90.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
